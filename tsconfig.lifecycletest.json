{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": ".lifecycletest-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/core/**/*.ts",
    "src/data/**/*.ts",
    "src/gameplay/**/*.ts",
    "src/people/**/*.ts",
    "src/simulation/**/*.ts",
    "src/world/**/*.ts",
    "tests/lifecycleSimulationTest.ts",
    "tests/globals.d.ts"
  ],
  "exclude": [
    "src/**/*.tsx"
  ]
}